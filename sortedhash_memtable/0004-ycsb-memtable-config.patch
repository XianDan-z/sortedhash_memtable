     final MemTableConfig memTableConfig = getMemTableConfig();
+    final boolean allowConcurrentWrite = isConcurrentWriteSupported();
 
     if(cfDescriptors.isEmpty()) {
       final Options options = new Options()
@@ -165,6 +171,9 @@ public class RocksDBClient extends DB {
           .setIncreaseParallelism(rocksThreads)
           .setMaxBackgroundCompactions(rocksThreads)
           .setInfoLogLevel(InfoLogLevel.INFO_LEVEL);
+      if (!allowConcurrentWrite) {
+        options.setAllowConcurrentMemtableWrite(false);
+      }
       if (memTableConfig != null) {
         options.setMemTableConfig(memTableConfig);
       }
@@ -177,6 +186,9 @@ public class RocksDBClient extends DB {
           .setIncreaseParallelism(rocksThreads)
           .setMaxBackgroundCompactions(rocksThreads)
           .setInfoLogLevel(InfoLogLevel.INFO_LEVEL);
+      if (!allowConcurrentWrite) {
+        options.setAllowConcurrentMemtableWrite(false);
+      }
       dbOptions = options;
 
       if (memTableConfig != null) {
@@ -222,6 +234,22 @@ public class RocksDBClient extends DB {
     }
   }
 
+  /**
+   * Returns true if the configured memtable supports concurrent writes.
+   * HashSkipList, HashLinkList, and VectorRep do NOT support concurrent writes.
+   */
+  private boolean isConcurrentWriteSupported() {
+    String memtableType = getProperties().getProperty(PROPERTY_ROCKSDB_MEMTABLE, "skip_list");
+    switch (memtableType.toLowerCase()) {
+      case "prefix_hash":
+      case "hash_linkedlist":
+      case "vector":
+        return false;
+      default:
+        return true;
+    }
+  }
+

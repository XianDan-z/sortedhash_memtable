+inline SortHeapItem* AllocSortHeapItem(SpdbVectorPtr vec,
+                                        SpdbVector::Iterator iter) {
+  static thread_local std::vector<SortHeapItem*> cache;
+  if (!cache.empty()) {
+    SortHeapItem* item = cache.back();
+    cache.pop_back();
+    item->Reset(vec, iter);
+    return item;
+  }
+  return new SortHeapItem(vec, iter);
+}
+
+inline void FreeSortHeapItem(SortHeapItem* item) {
+  static thread_local std::vector<SortHeapItem*> cache;
+  if (cache.size() < 64) {
+    cache.push_back(item);
+  } else {
+    delete item;
+  }
+}
